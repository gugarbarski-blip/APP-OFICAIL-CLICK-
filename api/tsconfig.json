{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "lib": ["ES2020"],
    "skipLibCheck": true,
    "types": ["node"],
    "strict": false,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "outDir": "../.vercel/functions"
  },
  "include": ["./**/*.ts", "../lib/**/*.ts"]
}
